{
    "name": "rekro",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "npm run dev:clean && next dev",
        "dev:clean": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$ErrorActionPreference='SilentlyContinue'; Get-CimInstance Win32_Process | Where-Object { $_.Name -eq 'node.exe' -and $_.CommandLine -like '*D:\\\\BUSINESS\\\\Rekro\\\\rekro\\\\node_modules\\\\next\\\\dist\\\\server\\\\lib\\\\start-server.js*' } | ForEach-Object { Stop-Process -Id $_.ProcessId -Force }; Remove-Item -Recurse -Force .next -ErrorAction SilentlyContinue\"",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "typecheck": "tsc --noEmit",
        "test": "playwright test",
        "test:ui": "playwright test --ui",
        "test:headed": "playwright test --headed",
        "test:chromium": "playwright test --project=chromium",
        "test:firefox": "playwright test --project=firefox",
        "test:webkit": "playwright test --project=webkit",
        "test:mobile": "playwright test --project='Mobile Chrome' --project='Mobile Safari'",
        "test:debug": "playwright test --debug",
        "test:report": "playwright show-report",
        "email:preview": "email dev --dir src/lib/email --port 3001"
    },
    "dependencies": {
        "@react-email/components": "^1.0.8",
        "@react-email/render": "^2.0.4",
        "@react-google-maps/api": "^2.20.8",
        "@sentry/nextjs": "^10.40.0",
        "@supabase/ssr": "^0.8.0",
        "@supabase/supabase-js": "^2.91.1",
        "@t3-oss/env-nextjs": "^0.13.11",
        "@tanstack/react-query": "^5.90.20",
        "@tanstack/react-virtual": "^3.13.19",
        "@upstash/ratelimit": "^2.0.8",
        "@upstash/redis": "^1.37.0",
        "@vercel/analytics": "^2.0.1",
        "@vercel/speed-insights": "^2.0.0",
        "clsx": "^2.1.1",
        "critters": "^0.0.23",
        "date-fns": "^4.1.0",
        "embla-carousel-autoplay": "^8.6.0",
        "embla-carousel-react": "^8.6.0",
        "focus-trap-react": "^12.0.0",
        "jspdf": "^4.2.0",
        "libphonenumber-js": "^1.12.38",
        "lucide-react": "^1.6.0",
        "next": "16.1.5",
        "nuqs": "^2.8.9",
        "prettier": "^3.8.1",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-error-boundary": "^6.1.1",
        "react-intersection-observer": "^10.0.3",
        "resend": "^6.9.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@next/bundle-analyzer": "^16.2.1",
        "@playwright/test": "^1.58.2",
        "@react-email/preview-server": "^5.2.9",
        "@tailwindcss/postcss": "^4",
        "@tanstack/react-query-devtools": "^5.91.2",
        "@types/google.maps": "^3.58.1",
        "@types/node": "^20.19.35",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "babel-plugin-react-compiler": "1.0.0",
        "eslint": "^9",
        "eslint-config-next": "16.1.4",
        "react-email": "^5.2.9",
        "tailwindcss": "^4",
        "typescript": "^5"
    }
}
